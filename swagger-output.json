{
  "openapi": "3.0.0",
  "info": {
    "title": "API Rede Social v2 – MySQL",
    "description": "API REST migrada para banco relacional MySQL. Inclui autenticação JWT, rota pública de status e CRUD protegido de Categorias.",
    "version": "2.0.0",
    "contact": {
      "name": "Sara Amabili Castilhos"
    }
  },
  "servers": [
    {
      "url": "http://localhost:3000"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Token JWT obtido em /api/auth/login. Cole aqui apenas o token (sem a palavra Bearer)."
      }
    },
    "schemas": {
      "RegisterBody": {
        "type": "object",
        "required": [
          "nome",
          "email",
          "password"
        ],
        "properties": {
          "nome": {
            "type": "string",
            "example": "Sara Castilhos"
          },
          "email": {
            "type": "string",
            "example": "sara@email.com"
          },
          "password": {
            "type": "string",
            "example": "senha123"
          }
        }
      },
      "LoginBody": {
        "type": "object",
        "required": [
          "email",
          "password"
        ],
        "properties": {
          "email": {
            "type": "string",
            "example": "sara@email.com"
          },
          "password": {
            "type": "string",
            "example": "senha123"
          }
        }
      },
      "AuthResponse": {
        "type": "object",
        "properties": {
          "id_usuario": {
            "type": "integer",
            "example": 1
          },
          "nome": {
            "type": "string",
            "example": "Sara Castilhos"
          },
          "email": {
            "type": "string",
            "example": "sara@email.com"
          },
          "token": {
            "type": "string",
            "example": "eyJhbGci..."
          }
        }
      },
      "CategoriaBody": {
        "type": "object",
        "required": [
          "nome"
        ],
        "properties": {
          "nome": {
            "type": "string",
            "example": "Eletrônicos"
          }
        }
      },
      "Categoria": {
        "type": "object",
        "properties": {
          "id_categoria": {
            "type": "integer",
            "example": 1
          },
          "nome": {
            "type": "string",
            "example": "Eletrônicos"
          }
        }
      },
      "StatusResponse": {
        "type": "object",
        "properties": {
          "versao": {
            "type": "string",
            "example": "2.0.0"
          },
          "status": {
            "type": "string",
            "example": "online"
          },
          "banco": {
            "type": "string",
            "example": "MySQL"
          },
          "descricao": {
            "type": "string",
            "example": "API Rede Social – migrada para banco relacional"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "msg": {
            "type": "string",
            "example": "Mensagem de erro"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Status",
      "description": "Rota pública de monitoramento – não requer autenticação"
    },
    {
      "name": "Autenticação",
      "description": "Registro e login de usuários"
    },
    {
      "name": "Categorias",
      "description": "CRUD de categorias – requer **dois** controles de acesso:\n\n1. Header `Authorization: Bearer <token>` obtido no login.\n2. Header `x-user-id` com o `id_usuario` retornado no login (deve coincidir com o token).\n\nSem ambos os headers, a requisição é bloqueada com 401 ou 403."
    }
  ],
  "paths": {
    "/api/status": {
      "get": {
        "tags": [
          "Status"
        ],
        "summary": "Verificar status e versão da API (público – sem autenticação)",
        "responses": {
          "200": {
            "description": "API online",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StatusResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/register": {
      "post": {
        "tags": [
          "Autenticação"
        ],
        "summary": "Registrar novo usuário",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterBody"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Usuário criado com sucesso – guarde o token e o id_usuario para usar nas rotas de Categorias",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "400": {
            "description": "E-mail já cadastrado ou dados inválidos"
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": [
          "Autenticação"
        ],
        "summary": "Login – retorna token JWT e id_usuario",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginBody"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login realizado – copie o token para o botão Authorize e o id_usuario para o header x-user-id",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "401": {
            "description": "Credenciais inválidas"
          }
        }
      }
    },
    "/api/categorias": {
      "get": {
        "tags": [
          "Categorias"
        ],
        "summary": "Listar todas as categorias",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "in": "header",
            "name": "x-user-id",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "ID do usuário autenticado (id_usuario retornado no login)"
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de categorias",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Categoria"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Token ausente ou x-user-id não informado"
          },
          "403": {
            "description": "x-user-id não corresponde ao token"
          }
        }
      },
      "post": {
        "tags": [
          "Categorias"
        ],
        "summary": "Criar nova categoria",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "in": "header",
            "name": "x-user-id",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "ID do usuário autenticado"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CategoriaBody"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Categoria criada",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Categoria"
                }
              }
            }
          },
          "400": {
            "description": "Dados inválidos (nome vazio)"
          },
          "401": {
            "description": "Não autorizado"
          }
        }
      }
    },
    "/api/categorias/{id}": {
      "get": {
        "tags": [
          "Categorias"
        ],
        "summary": "Buscar categoria por ID",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "ID da categoria"
          },
          {
            "in": "header",
            "name": "x-user-id",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "ID do usuário autenticado"
          }
        ],
        "responses": {
          "200": {
            "description": "Categoria encontrada",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Categoria"
                }
              }
            }
          },
          "401": {
            "description": "Não autorizado"
          },
          "404": {
            "description": "Categoria não encontrada"
          }
        }
      },
      "put": {
        "tags": [
          "Categorias"
        ],
        "summary": "Atualizar categoria",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "ID da categoria"
          },
          {
            "in": "header",
            "name": "x-user-id",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "ID do usuário autenticado"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CategoriaBody"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Categoria atualizada",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Categoria"
                }
              }
            }
          },
          "401": {
            "description": "Não autorizado"
          },
          "404": {
            "description": "Categoria não encontrada"
          }
        }
      },
      "delete": {
        "tags": [
          "Categorias"
        ],
        "summary": "Remover categoria",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "ID da categoria"
          },
          {
            "in": "header",
            "name": "x-user-id",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "ID do usuário autenticado"
          }
        ],
        "responses": {
          "200": {
            "description": "Categoria removida com sucesso"
          },
          "401": {
            "description": "Não autorizado"
          },
          "404": {
            "description": "Categoria não encontrada"
          }
        }
      }
    }
  }
}